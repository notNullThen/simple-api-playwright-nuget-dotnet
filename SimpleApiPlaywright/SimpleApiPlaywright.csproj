<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>SimpleApiPlaywright</PackageId>
    <Version>1.0.0</Version>
    <Authors>Eugene</Authors>
    <Description>Playwright-based API client framework.</Description>
    <RepositoryUrl>https://github.com/notNullThen/simple-api-playwright-dotnet</RepositoryUrl>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Playwright" Version="1.59.0" />
  </ItemGroup>
</Project>
